<?xml version="1.0" encoding="UTF-8"?>
<mdscript xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="VAS_CopyStationLogistic_Config" xsi:noNamespaceSchemaLocation="md.xsd">
  <!--
    Extension Options UI + config state for Copy Station Logistic. The gameplay
    script (copy_station_logistic.xml) reads md.VAS_CopyStationLogistic_Config.ModConfig
    cross-script; the Lua side reads the player.entity.$vas_csl_debug_chance mirror.
  -->
  <cues>
    <!-- Config STATE container. Defaults live in exactly one place: SeedDefaults. -->
    <cue name="ModConfig" namespace="this">
      <actions>
        <run_actions ref="SeedDefaults"/>
      </actions>
    </cue>

    <!--@doc
        Idempotent defaults seeder. String-coercion null checks: explicit
        false/0 must NOT be re-seeded. -->
    <library name="SeedDefaults" purpose="run_actions">
      <actions>
        <do_if value="(@md.VAS_CopyStationLogistic_Config.ModConfig.$debugEnabled + '') == 'null'">
          <set_value name="md.VAS_CopyStationLogistic_Config.ModConfig.$debugEnabled" exact="false"/>
        </do_if>
      </actions>
    </library>

    <!-- event_universe_generated fires both at new-game start AND on every
         savegame load (md.xsd), so it alone covers all sessions. Seeds defaults
         and re-pushes the Lua blackboard mirror. -->
    <cue name="InitDefaults" instantiate="true">
      <conditions>
        <event_universe_generated/>
      </conditions>
      <actions>
        <run_actions ref="SeedDefaults"/>
        <set_value name="player.entity.$vas_csl_debug_chance" exact="if md.VAS_CopyStationLogistic_Config.ModConfig.$debugEnabled then 100 else 0"/>
      </actions>
    </cue>

    <cue name="StartSMO" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_Options.Reloaded"/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu" param="table[
          $id = 'vas_csl_options_menu',
          $columns = 2,
          $title = {202600517,30},
          $onOpen = BuildOptionsMenu,
        ]"/>
        <cancel_cue cue="this"/>
      </actions>
    </cue>

    <cue name="BuildOptionsMenu" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Call_Table_Method" param="table[
          $method = 'setColWidth',
          $col = 1,
          $width = 'Helper.standardButtonHeight',
        ]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $id = 'debugEnabled',
          $checked = @md.VAS_CopyStationLogistic_Config.ModConfig.$debugEnabled,
          $col = 1,
          $width = 'Helper.standardButtonHeight',
          $height = 'Helper.standardButtonHeight',
          $onClick = OnOptionsCheckboxChanged,
        ]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[
          $col = 2,
          $text = {202600517,31},
        ]"/>
      </actions>
    </cue>

    <cue name="OnOptionsCheckboxChanged" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="md.VAS_CopyStationLogistic_Config.ModConfig.{'$' + event.param.$id}" exact="event.param.$checked"/>
        <do_if value="event.param.$id == 'debugEnabled'">
          <do_if value="event.param.$checked">
            <set_value name="player.entity.$vas_csl_debug_chance" exact="100"/>
          </do_if>
          <do_else>
            <set_value name="player.entity.$vas_csl_debug_chance" exact="0"/>
          </do_else>
        </do_if>
        <cancel_cue cue="this"/>
      </actions>
    </cue>
  </cues>
</mdscript>
